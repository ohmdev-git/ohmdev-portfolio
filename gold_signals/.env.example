# Gold Signal Bot — copy this file to .env and fill in your values
# Never commit .env to git!

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Talk to @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2. Add bot to your group, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  to find your chat_id
TELEGRAM_CHAT_ID=-1001234567890

# ── Discord ────────────────────────────────────────────────────────────────────
# Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# ── LINE Notify ────────────────────────────────────────────────────────────────
# https://notify-bot.line.me/ → Generate token → pick your group/1-on-1
LINE_NOTIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI-Trader (ai4trade.ai) ────────────────────────────────────────────────────
# Set AI_TRADER_ENABLED=true to publish signals to the AI-Trader platform
# Register at https://ai4trade.ai to get credentials
AI_TRADER_ENABLED=false
AI_TRADER_EMAIL=your@email.com
AI_TRADER_PASSWORD=yourpassword
# Symbol to trade on AI-Trader (default: XAUUSD for gold)
AI_TRADER_SYMBOL=XAUUSD
# Market type: crypto | stocks | polymarket
AI_TRADER_MARKET_TYPE=crypto

# ── Timing ─────────────────────────────────────────────────────────────────────
# How often to check for signals (seconds). 300 = every 5 minutes
CHECK_INTERVAL=300
# Minimum time between repeated signals of the same direction (seconds)
SIGNAL_COOLDOWN=3600
